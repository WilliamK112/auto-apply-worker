# Auto-Apply Worker — Environment Variables
# Copy this file to .env and fill in the values

# ── Application OS ──────────────────────────────────────────────────────────────
# The base URL of your application-os deployment
AUTO_APPLY_APP_OS_URL=https://application-os.vercel.app

# Shared secret — must match AUTO_APPLY_WORKER_SECRET in application-os .env.local
AUTO_APPLY_WORKER_SECRET=change-me-to-a-long-random-string

# Which user's queue to process (find in application-os database)
AUTO_APPLY_USER_ID=user_1

# ── Worker Profile (Your Personal Info) ───────────────────────────────────────
# The bot uses these to fill application forms
AUTO_APPLY_EMAIL=your.email@example.com
AUTO_APPLY_PHONE=+13478668326

# Path to your resume PDF (absolute path on the server)
# Example: /Users/you/Documents/resume.pdf
AUTO_APPLY_RESUME_PATH=/path/to/your/resume.pdf

# ── Browser & Timing ───────────────────────────────────────────────────────────
# Set to "false" to see the browser (useful for debugging locally)
AUTO_APPLY_HEADLESS=true

# Milliseconds to wait between processing jobs (LinkedIn rate limits after ~50/day)
AUTO_APPLY_DELAY_MS=8000
